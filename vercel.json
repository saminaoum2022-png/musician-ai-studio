{
  "cleanUrls": true,
  "trailingSlash": false,
  "functions": {
    "api/suno/stems.js": {
      "includeFiles": "node_modules/ffmpeg-static/**"
    }
  },
  "rewrites": [
    { "source": "/s/:id", "destination": "/api/share?id=:id" }
  ],
  "headers": [
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, must-revalidate" }
      ]
    },
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, must-revalidate" }
      ]
    },
    {
      "source": "/src/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, must-revalidate" }
      ]
    },
    {
      "source": "/styles.css",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, must-revalidate" }
      ]
    }
  ]
}
