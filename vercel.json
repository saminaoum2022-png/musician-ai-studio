{
  "buildCommand": "node scripts/sync-client-env.mjs",
  "outputDirectory": ".",
  "cleanUrls": true,
  "trailingSlash": false,
  "functions": {
    "api/suno/stems.js": {
      "includeFiles": "node_modules/ffmpeg-static/**"
    },
    "api/suno/upload-audio.js": {
      "includeFiles": "node_modules/ffmpeg-static/**"
    },
    "api/render-video.js": {
      "includeFiles": "node_modules/ffmpeg-static/**",
      "maxDuration": 60
    },
    "api/songs/archive.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/s/:id", "destination": "/api/share?id=:id" }
  ],
  "headers": [
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, must-revalidate" }
      ]
    },
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, must-revalidate" }
      ]
    },
    {
      "source": "/src/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, must-revalidate" }
      ]
    },
    {
      "source": "/styles.css",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, must-revalidate" }
      ]
    },
    {
      "source": "/assets/icons/splash-logo.mp4",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/privacy",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, must-revalidate" }
      ]
    },
    {
      "source": "/terms",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, must-revalidate" }
      ]
    }
  ]
}
